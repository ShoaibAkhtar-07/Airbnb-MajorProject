<% layout("layouts/boilerplate") -%>
    <style>
        .filters-wrapper {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        #filters {
            display: flex;
            overflow-x: auto;
            gap: 1.3rem;
            flex: 1;
            scroll-behavior: smooth;
        }

        #filters::-webkit-scrollbar {
            display: none;
        }

        .filter {
            min-width: 80px;
            text-align: center;
            opacity: 0.7;
            flex-shrink: 0;
        }

        .filter:hover {
            opacity: 1;
            cursor: pointer;
        }

        .scroll-btn {
            border: none;
            background: white;
            font-size: 1.5rem;
            cursor: pointer;
        }

        /* Tax toggle right side */
        .tax-toggle {
            border: 1px solid black;
            border-radius: 1rem;
            padding: 0.5rem 1rem;
            white-space: nowrap;
        }

        .tax-info {
            display: none;
        }

        @media (max-width: 300px) {
            .tax-toggle {
                display: none;
            }
        }


        @media (max-width: 450px) {
            #scrollRight {
                display: none;
            }

            #filters {
                display: none;
            }
        }
    </style>
    <div class="filters-wrapper">
        <div id="filters">
            <div class="filter">
                <i class="fa-solid fa-table-cells"></i>
                <p>All</p>
            </div>

            <div class="filter">
                <i class="fa-solid fa-fire"></i>
                <p>Trending</p>
            </div>

            <div class="filter">
                <i class="fa-solid fa-bed"></i>
                <p>Bed</p>
            </div>

            <div class="filter">
                <i class="fa-solid fa-mountain-city"></i>
                <p>Mountain</p>
            </div>

            <div class="filter">
                <i class="fa-solid fa-umbrella-beach"></i>
                <p>Beach</p>
            </div>

            <div class="filter">
                <i class="fa-solid fa-panorama"></i>
                <p>View</p>
            </div>

            <div class="filter">
                <i class="fa-solid fa-person-swimming"></i>
                <p>Pools</p>
            </div>

            <div class="filter">
                <i class="fa-brands fa-fort-awesome"></i>
                <p>Castle</p>
            </div>

            <div class="filter">
                <i class="fa-solid fa-person-hiking"></i>
                <p>Hiking</p>
            </div>
        </div>

        <button id="scrollRight" class="scroll-btn">
            <i class="fa-solid fa-circle-arrow-right"></i>
        </button>


        <div class="tax-toggle">
            <div class="form-check form-switch d-flex align-items-center gap-2">
                <input class="form-check-input" type="checkbox" id="switchCheckDefault">
                <label class="form-check-label mb-0">
                    Display total after Taxes
                </label>
            </div>
        </div>

    </div>

    <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 row-cols-2 mt-3">
        <%for(let listing of allListing){%>
            <div class="col">
                <a href="/listings/<%=listing._id %>" class="listing-links">
                    <div class="card listing-card">
                        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image">
                        <div class="card-img-overlay"></div>
                        <div class="card-body">
                            <p class="card-text">
                                <b>
                                    <%=listing.title%>
                                </b>
                                <br>
                                &#8377;<%= listing.price.toLocaleString("en-IN") %> /night
                                    <i class="tax-info">&nbsp;&nbsp;+18% GST</i>
                            </p>
                        </div>
                    </div>
                </a>
            </div>
            <%}%>
    </div>

    <script>
        let afterTaxPrice = document.getElementById("switchCheckDefault");
        afterTaxPrice.addEventListener("click", () => {
            let tax_info = document.getElementsByClassName("tax-info");
            for (info of tax_info) {
                if (info.style.display !== "inline") {
                    info.style.display = "inline";
                } else {
                    info.style.display = "none";
                }
            }
        });


        const filters = document.getElementById("filters");
        const scrollBtn = document.getElementById("scrollRight");
        scrollBtn.addEventListener("click", () => {
            filters.scrollBy({
                left: 200,
                behavior: "smooth"
            });
        });
    </script>