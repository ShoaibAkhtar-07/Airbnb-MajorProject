<% layout("/layouts/boilerplate.ejs")-%>
    <div class="login-wrapper">
        <div class="wl-page">
            <div class="wl-card">
                <h2 class="wl-title">Welcome back</h2>
                <p class="wl-sub">Don't have an account? <a href="/signup">Sign up</a></p>

                <form action="/login" method="post" novalidate>
                    <div class="wl-field">
                        <label class="wl-label" for="username">Username</label>
                        <div class="wl-input-wrap">
                            <span class="wl-input-icon">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                    <circle cx="12" cy="7" r="4" />
                                </svg>
                            </span>
                            <input class="wl-input" type="text" name="username" id="username"
                                placeholder="Enter your username" required>
                        </div>
                    </div>

                    <div class="wl-field">
                        <label class="wl-label" for="password">Password</label>
                        <div class="wl-input-wrap">
                            <span class="wl-input-icon">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                </svg>
                            </span>
                            <input class="wl-input" type="password" name="password" id="password"
                                placeholder="Enter your password" required>
                            <span class="wl-eye"
                                onclick="var i=document.getElementById('password');i.type=i.type==='password'?'text':'password'">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                            </span>
                        </div>
                    </div>

                    <button type="submit" class="wl-btn">Log In &nbsp;→</button>
                </form>

                <p class="wl-terms">By logging in, you agree to our <a href="#">Terms of Service.</a></p>
            </div>
        </div>
    </div>